# --- Backend ---
# Maximum upload size in megabytes
MAX_UPLOAD_MB=100

# Subprocess timeout (seconds) per conversion
CONVERSION_TIMEOUT=600

# Where temporary files and shareable conversions are stored
STORAGE_DIR=/tmp/pdf2djvu

# How long (seconds) a stored conversion lives before being purged
STORAGE_TTL_SECONDS=3600

# Comma-separated list of allowed CORS origins (use * only in dev)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limit: e.g. "30/hour", "5/minute"
RATE_LIMIT_CONVERT=30/hour
RATE_LIMIT_COMPARE=60/hour

# Default OCR language (Tesseract code, e.g. eng, deu, fra, jpn)
OCR_LANGUAGE=eng

# OCR engine selection: auto | tesseract | easyocr
#   auto       — EasyOCR if a CUDA GPU is detected, else Tesseract (recommended)
#   tesseract  — always use CPU Tesseract via ocrmypdf
#   easyocr    — force GPU EasyOCR (falls back to Tesseract if not installed)
OCR_ENGINE=auto

# --- Frontend ---
# URL the browser should call to reach the API
VITE_API_BASE=http://localhost:8000
